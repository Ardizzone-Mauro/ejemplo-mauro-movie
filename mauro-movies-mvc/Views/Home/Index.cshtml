@model List<Pelicula>




@{
    ViewData["Title"] = "Home Page";
}

<!-- Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&amp;display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />


<style>
    :root {
        --primary-accent: #E50914;
        --surface-bg: #0e0e0e;
        --surface-container: #1a1a1a;
        --surface-container-low: #131313;
        --on-surface: #ffffff;
        --on-surface-variant: #adaaaa;
        --secondary: #37bcf7;
        --tertiary: #d7a0ff;
    }

    body {
        background-color: var(--surface-bg);
        color: var(--on-surface);
        font-family: 'Inter', sans-serif;
        overflow-x: hidden;
    }

    /* Navigation */
    .navbar {
        background-color: rgba(14, 14, 14, 0.7);
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        height: 80px;
        padding: 0 2rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    /* .navbar-brand {
        font-weight: 900;
        font-size: 1.5rem;
        color: var(--primary-accent) !important;
        letter-spacing: -1px;
        text-transform: uppercase;
    } */

    /* .nav-link {
        color: var(--on-surface-variant) !important;
        font-weight: 500;
        letter-spacing: -0.2px;
        padding: 0.5rem 1rem !important;
        transition: color 0.3s ease;
    } */

        .nav-link.active {
            color: #fff !important;
            border-bottom: 2px solid var(--primary-accent);
        }

        .nav-link:hover {
            color: #fff !important;
        }

    .btn-icon {
        background: transparent;
        border: none;
        color: var(--on-surface);
        padding: 8px;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

        .btn-icon:hover {
            background: var(--surface-container);
            transform: scale(0.95);
        }

    /* Hero Section */
    .hero-section {
        position: relative;
        height: 90vh;
        min-height: 700px;
        display: flex;
        align-items: flex-end;
        padding-bottom: 100px;
        overflow: hidden;
    }

    .hero-backdrop {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
    }

        .hero-backdrop img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: brightness(0.4);
        }

    .hero-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, var(--surface-bg) 0%, transparent 60%), linear-gradient(to right, var(--surface-bg) 0%, transparent 70%);
    }

    .hero-content {
        position: relative;
        z-index: 10;
        max-width: 900px;
    }

    .hero-label {
        display: inline-block;
        background: rgba(229, 9, 20, 0.2);
        color: #ff7668;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 4px 12px;
        border: 1px solid rgba(229, 9, 20, 0.3);
        border-radius: 2px;
        margin-bottom: 1.5rem;
    }

    .hero-title {
        font-size: 6rem;
        font-weight: 900;
        letter-spacing: -4px;
        line-height: 0.9;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
    }

    .hero-meta {
        color: var(--on-surface-variant);
        font-weight: 500;
        margin-bottom: 1.5rem;
    }

    .genre-badge {
        font-size: 10px;
        text-transform: uppercase;
        padding: 2px 8px;
        border: 1px solid var(--on-surface-variant);
    }

    .btn-primary-custom {
        background: linear-gradient(90deg, #e80f16, #ff8e80);
        border: none;
        color: #650003;
        font-weight: 700;
        padding: 1rem 2.5rem;
        border-radius: 4px;
        transition: transform 0.2s ease;
    }

        .btn-primary-custom:hover {
            transform: scale(1.05);
            color: #650003;
        }

    .btn-secondary-custom {
        background: var(--surface-container);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        font-weight: 700;
        padding: 1rem 2.5rem;
        border-radius: 4px;
        transition: background 0.3s ease;
    }

        .btn-secondary-custom:hover {
            background: #2c2c2c;
            color: #fff;
        }

    /* Bento Grid */
    .bento-section {
        background-color: var(--surface-container-low);
        padding: 80px 0;
    }

    .section-header {
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .section-title {
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: -1px;
        margin-bottom: 0.25rem;
    }

    .section-subtitle {
        font-size: 12px;
        color: var(--on-surface-variant);
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .view-all-link {
        color: var(--primary-accent);
        text-decoration: none;
        font-weight: 700;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-bottom: 2px solid var(--primary-accent);
        padding-bottom: 4px;
    }

    .bento-container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-template-rows: repeat(2, 300px);
        gap: 1.5rem;
    }

    .bento-item {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
    }

        .bento-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.7s ease;
        }

        .bento-item:hover img {
            transform: scale(1.1);
        }

        .bento-item.large {
            grid-column: span 2;
            grid-row: span 2;
        }

    .bento-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 60%);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 2rem;
    }

    .bento-title {
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -1px;
        margin-bottom: 0.5rem;
    }

    /* Movie Horizontal Rows */
    .movie-row {
        padding: 80px 0;
    }

        .movie-row.alt {
            background-color: var(--surface-container-low);
        }

    .category-header {
        border-left: 4px solid var(--primary-accent);
        padding-left: 1rem;
        margin-bottom: 2rem;
        text-transform: uppercase;
        font-weight: 800;
    }

   

    .horizontal-scroll {
        display: grid;
        /* grid-template-columns: repeat(3, 1fr); /* 3 por fila */ 
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));/*se adapten solas según el tamaño de pantalla */
        gap: 1.5rem;
    }


  

        .movie-card img {
            width: 100%;
            aspect-ratio: 2/3;
            object-fit: cover;
            border-radius: 8px;
            transition: transform 0.5s ease;
        }

        .movie-card:hover img {
            transform: scale(1.05);
        }

    .movie-card-title {
        margin-top: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        transition: color 0.3s ease;
    }

    .movie-card:hover .movie-card-title {
        color: var(--primary-accent);
    }

    .movie-card-meta {
        display: flex;
        justify-content: space-between;
        color: var(--on-surface-variant);
        font-size: 14px;
    }

    .stars {
        color: var(--secondary);
        font-size: 14px;
    }

    /* Footer */
    footer {
        padding: 80px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        text-align: center;
    }

    .footer-links {
        display: flex;
        justify-content: center;
        gap: 3rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

        .footer-links a {
            color: var(--on-surface-variant);
            text-decoration: underline;
            text-decoration-color: var(--primary-accent);
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 1px;
            transition: color 0.3s ease;
        }

            .footer-links a:hover {
                color: #fff;
            }

    .copyright {
        color: var(--on-surface-variant);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Material Symbols adjustment */
    .material-symbols-outlined {
        vertical-align: middle;
        font-size: 20px;
    }

    .fill {
        font-variation-settings: 'FILL' 1;
    }

   

</style>
<!-- Hero Section -->
<section class="hero-section">
