<!-- Movie Row: Action -->
<section class="movie-row">
    <div class="container-fluid px-5">
        <div class="horizontal-scroll">

            @foreach (var pelicula in Model)
            {
                
            <div class="movie-card">
                <div class="position-relative">
                    <img alt="@pelicula.Titulo" src="@pelicula.PosterUrlPortada" />
                    <div class="position-absolute top-0 end-0 m-3 badge bg-black bg-opacity-75">4K HDR</div>
                </div>
                <h3 class="movie-card-title h6">@pelicula.Titulo</h3>
                <div class="movie-card-meta">
                    <span>@pelicula.FechaLanzamiento</span>
                    <div class="stars">
                        <span class="material-symbols-outlined fill">star</span>
                        <span class="material-symbols-outlined fill">star</span>
                        <span class="material-symbols-outlined fill">star</span>
                        <span class="material-symbols-outlined fill">star</span>
                        <span class="material-symbols-outlined fill">star</span>
                    </div>
                </div>
            </div>
            }
        </div>
    </div>
</section>
